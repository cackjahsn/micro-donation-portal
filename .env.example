# Environment Configuration
# Copy this file to .env and update with your actual credentials
# NEVER commit .env file to version control

# Database Configuration
DB_HOST=localhost
DB_NAME=micro_donation_db
DB_USER=root
DB_PASS=

# Application Environment
# Options: development, production
APP_ENV=development

# Application Settings
APP_NAME=CommunityGive
APP_URL=http://localhost/micro-donation-portal

# Session Settings
SESSION_LIFETIME=30
SESSION_SECURE=false

# Email Configuration (if needed)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Security
# Generate a random 32-character string for production
APP_KEY=

# API Keys (if integrating external services)
# STRIPE_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Feature Flags
ENABLE_DEBUG=false
ENABLE_ERROR_LOGGING=true
